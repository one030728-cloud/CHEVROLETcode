PORT=3000

# 솔라피 (알림톡)
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER=
SOLAPI_KAKAO_PFID=

# 예약 접수 시 대기번호+남은 인원 안내 (대기중인 손님이 있을 때만 발송. 없으면 바로 순서 호출 템플릿이 나감)
SOLAPI_KAKAO_TEMPLATE_RESERVATION=
# 매장에서 순서를 호출할 때 "고객님의 순서입니다" 안내
SOLAPI_KAKAO_TEMPLATE_QUEUE_TURN=
# 결제 완료 전자영수증
SOLAPI_KAKAO_TEMPLATE_RECEIPT=
# 결제 3개월 후 자동 발송되는 홍보 알림톡
SOLAPI_KAKAO_TEMPLATE_PROMO=

# 관리자 API(GET /api/reservations/failed, /api/payments/failed, POST /api/queue/call-next)용 토큰. 임의의 긴 랜덤 문자열로 설정.
ADMIN_TOKEN=
